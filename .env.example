# Frontend — Vite / Netlify
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or .env — both are git-ignored.

# Supabase project URL
# Found in: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to expose in browser)
# Found in: Supabase Dashboard → Project Settings → API → anon public
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here

# Supabase project reference ID (used by CI for edge function deploys)
# Found in: Supabase Dashboard → Project Settings → General → Reference ID
VITE_SUPABASE_PROJECT_ID=your-project-ref
