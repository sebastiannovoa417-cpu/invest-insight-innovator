# Copy this file to .env and fill in your values.
# Never commit the actual .env — it is git-ignored.

# Supabase Edge Function URL
# Format: https://<your-project-ref>.supabase.co/functions/v1/sync-data
SUPABASE_SYNC_URL=https://your-project-ref.supabase.co/functions/v1/sync-data

# Must match the SYNC_API_KEY secret set in Supabase Dashboard
# → Edge Functions → sync-data → Secrets
SYNC_API_KEY=your-sync-api-key-here
