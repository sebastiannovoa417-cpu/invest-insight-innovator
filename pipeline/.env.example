# Copy this file to .env and fill in your values.
# Never commit the actual .env — it is git-ignored.

# Supabase Edge Function URL
# Format: https://<your-project-ref>.supabase.co/functions/v1/sync-ingest
SUPABASE_SYNC_URL=https://cbvuewxjacuqyxkpwoum.supabase.co/functions/v1/sync-ingest

# Authentication key sent as the x-api-key header to the sync-ingest edge function.
# Option A (recommended): Set a dedicated SYNC_API_KEY in both GitHub Actions secrets
#   AND in the Supabase Dashboard → Edge Functions → sync-ingest → Secrets.
# Option B (zero-config fallback): Set SUPABASE_SERVICE_ROLE_KEY in GitHub Actions
#   secrets. The edge function will accept this automatically since it is a
#   built-in Supabase env var that requires no Supabase-side configuration.
SYNC_API_KEY=your-sync-api-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Supabase Edge Function URL for prices
SUPABASE_PRICES_URL=https://cbvuewxjacuqyxkpwoum.supabase.co/functions/v1/sync-prices

#  moomoo Enrichment (local only  NOT used in GitHub Actions) 
# Direct PostgreSQL connection string.
# Find it in: Supabase Dashboard  Settings  Database  Connection string  URI
# Replace [YOUR-PASSWORD] with your database password.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.cbvuewxjacuqyxkpwoum.supabase.co:5432/postgres

# Optional overrides for FutuOpenD connection (defaults shown)
# FUTU_HOST=127.0.0.1
# FUTU_PORT=11111
