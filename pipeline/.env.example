# Copy this file to .env and fill in your values.
# Never commit the actual .env — it is git-ignored.

# Supabase Edge Function URL
# Format: https://<your-project-ref>.supabase.co/functions/v1/sync-ingest
SUPABASE_SYNC_URL=https://your-project-ref.supabase.co/functions/v1/sync-ingest

# Must match the SYNC_API_KEY secret set in Supabase Dashboard
# → Edge Functions → sync-ingest → Secrets
SYNC_API_KEY=your-sync-api-key-here

# ── moomoo Enrichment (local only — NOT used in GitHub Actions) ──────────────
# Service role key found in Supabase Dashboard → Settings → API → service_role
SUPABASE_URL=https://vffizmkzwfxpewtfoerm.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional overrides for FutuOpenD connection (defaults shown)
# FUTU_HOST=127.0.0.1
# FUTU_PORT=11111
